{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User account information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "scans": {
      "title": "Detection Scan",
      "description": "Historical AI detection results",
      "type": "object",
      "properties": {
        "score": { "type": "number" },
        "confidence": { "type": "number" },
        "label": { "type": "string" },
        "analysis": { "type": "string" },
        "textSnippet": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["score", "label", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Individual user profile documents"
    },
    "/users/{userId}/scans/{scanId}": {
      "schema": "scans",
      "description": "User's historical scan results"
    }
  }
}
